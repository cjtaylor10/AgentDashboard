{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentDashboard",
  "version": "0.1.3",
  "identifier": "com.agentdashboard.cockpit",
  "build": {
    "frontendDist": "http://localhost:4317"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "AgentDashboard",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../../sidecar/src": "sidecar/src",
      "../../sidecar/scripts": "sidecar/scripts",
      "../../sidecar/web": "sidecar/web",
      "../../sidecar/package.json": "sidecar/package.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cjtaylor10/AgentDashboard/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGRDE4MERENkRBNTY4NTcKUldSWGFLVnQzWURSYjhEVDcxcWcxRWJ6Mjg4d0FnMUZYVkFuOCtJV0ovUWs0QkU3T1VMR1BPSkcK"
    }
  }
}
